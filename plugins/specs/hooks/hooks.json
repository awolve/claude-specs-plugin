{
  "description": "Specs plugin — sync spec files with Awolve Spec Service",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/sync.py pull --quiet",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/sync.py post-tool-use",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
